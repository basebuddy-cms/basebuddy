{
  "name": "basebuddy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "@babel/runtime": "7.26.10",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "flatted": "3.4.2",
      "happy-dom": "20.8.9",
      "lodash": "4.18.1",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss": "8.5.13",
      "vite": "7.3.2",
      "yaml": "2.8.3"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev --port 8080",
    "dev:playwright": "node --env-file=.env.playwright ./node_modules/next/dist/bin/next dev --port 3100",
    "build": "next build",
    "build:e2e": "node --env-file=.env.playwright ./node_modules/next/dist/bin/next build",
    "build:playwright": "node --env-file=.env.playwright ./node_modules/next/dist/bin/next build",
    "start": "next start --port 8080",
    "start:playwright": "node ./scripts/start-playwright-server.mjs",
    "perf:build": "node ./scripts/measure-next-build.mjs",
    "perf:dev": "node ./scripts/measure-next-dev-compile.mjs",
    "perf:runtime": "node ./scripts/measure-playwright-runtime.mjs",
    "perf:bundles": "node --import tsx ./scripts/report-next-bundles.ts",
    "perf:budgets": "node --import tsx ./scripts/report-content-runtime-budgets.ts",
    "perf:seed-large": "node --import tsx ./scripts/seed-large-content-plane.ts",
    "perf:seed-large:clean": "node --import tsx ./scripts/seed-large-content-plane.ts --clean",
    "perf:large-api": "node --import tsx ./scripts/measure-large-content-api.ts",
    "perf:large-browser": "node --env-file=.env.playwright ./node_modules/@playwright/test/cli.js test e2e/large-content-performance.spec.ts",
    "lint": "next lint",
    "setup:check": "node --import tsx ./scripts/check-self-host-setup.ts",
    "e2e:seed": "node --import tsx ./scripts/setup-e2e.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm run build:e2e && node --env-file=.env.playwright ./node_modules/@playwright/test/cli.js test",
    "test:e2e:headed": "pnpm run build:e2e && node --env-file=.env.playwright ./node_modules/@playwright/test/cli.js test --headed",
    "test:e2e:ui": "pnpm run build:e2e && node --env-file=.env.playwright ./node_modules/@playwright/test/cli.js test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.83.0",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/html": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.462.0",
    "markdown-it": "^14.1.1",
    "next": "15.5.15",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.2",
    "vaul": "^0.9.9",
    "yoastseo": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-config-next": "15.5.15",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}

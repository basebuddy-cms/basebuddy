# BaseBuddy self-host settings
#
# Fresh setup does not require app-state env values. Run the app, open
# /onboarding, and BaseBuddy will create process.cwd()/basebuddy.config.json.
# That config file stores the owner account, projects, permissions, mapping,
# and sidebar layout. Keep credentials in env.

# Required secrets/credentials.
BASEBUDDY_AUTH_SECRET=
BASEBUDDY_CONTENT_DATABASE_URL=

# Optional. For Supabase media bucket storage.
# BASEBUDDY_SUPABASE_URL=https://your-project-ref.supabase.co
# BASEBUDDY_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# BASEBUDDY_SUPABASE_SECRET_KEY=your-server-key

# Optional. For S3 bucket storage.
# BASEBUDDY_S3_ACCESS_KEY_ID=your-s3-access-key
# BASEBUDDY_S3_SECRET_ACCESS_KEY=your-s3-secret-key

# Optional site settings.
NEXT_PUBLIC_SITE_INDEXABLE=false

# Optional build-time branding.
NEXT_PUBLIC_BASEBUDDY_APP_NAME=BaseBuddy
# NEXT_PUBLIC_BASEBUDDY_DOCS_URL=https://basebuddycms.com/docs
# NEXT_PUBLIC_BASEBUDDY_SUPPORT_URL=https://basebuddycms.com/support

# Optional public demo login.
# BASEBUDDY_DEMO_LOGIN_ENABLED=1
# BASEBUDDY_DEMO_USER_EMAIL=demo@basebuddycms.com
# BASEBUDDY_DEMO_USER_PASSWORD=replace-with-demo-password

# Optional Playwright/local E2E settings.
# BASEBUDDY_ENABLE_TEST_AUTH=1
# BASEBUDDY_PLAYWRIGHT_RUNTIME=1
# PLAYWRIGHT_BASE_URL=http://localhost:3100
# PLAYWRIGHT_PORT=3100
# PLAYWRIGHT_PROJECT_NAME=Playwright Self Host
# PLAYWRIGHT_PROJECT_SLUG=playwright-self-host
# PLAYWRIGHT_OWNER_EMAIL=pw-owner@example.com
# PLAYWRIGHT_OWNER_PASSWORD=replace-with-test-password

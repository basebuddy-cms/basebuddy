# Required to run BaseBuddy.
BASEBUDDY_AUTH_SECRET=
BASEBUDDY_CONTENT_DATABASE_URL=

# Optional: where BaseBuddy stores users, projects, mappings, permissions, and audit data.
# Leave blank for basebuddy-data/. Use supabase-same-project or supabase-split-project for DB-backed app data.
BASEBUDDY_APP_STATE_BACKEND=
BASEBUDDY_APP_STATE_DATABASE_URL=

# Optional: use Supabase buckets for images and files.
BASEBUDDY_SUPABASE_URL=
BASEBUDDY_SUPABASE_PUBLISHABLE_KEY=
BASEBUDDY_SUPABASE_SECRET_KEY=

# Optional: use S3 buckets for images and files.
BASEBUDDY_S3_ACCESS_KEY_ID=
BASEBUDDY_S3_SECRET_ACCESS_KEY=

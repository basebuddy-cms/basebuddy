# BaseBuddy self-host setup
#
# Start here for most installs: one Supabase project stores BaseBuddy setup data
# and the content tables you want to edit.
#
# After changing .env, restart BaseBuddy.

BASEBUDDY_SUPABASE_URL=https://your-project-ref.supabase.co
BASEBUDDY_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
BASEBUDDY_SUPABASE_SECRET_KEY=your-secret-key
BASEBUDDY_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
BASEBUDDY_AUTH_PROVIDERS=password,magic_link,google,github

# Optional: use separate Supabase projects when you want BaseBuddy setup data
# away from your content database. Leave the four values above unset when using
# these split-project values.
#
# BASEBUDDY_CONTROL_SUPABASE_URL=https://your-basebuddy-project-ref.supabase.co
# BASEBUDDY_CONTROL_SUPABASE_PUBLISHABLE_KEY=your-basebuddy-publishable-key
# BASEBUDDY_CONTROL_SUPABASE_SECRET_KEY=your-basebuddy-secret-key
# BASEBUDDY_CONTROL_DATABASE_URL=postgresql://postgres.your-basebuddy-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
#
# BASEBUDDY_CONTENT_SUPABASE_URL=https://your-content-project-ref.supabase.co
# BASEBUDDY_CONTENT_SUPABASE_PUBLISHABLE_KEY=your-content-publishable-key
# BASEBUDDY_CONTENT_SUPABASE_SECRET_KEY=your-content-secret-key
# BASEBUDDY_CONTENT_DATABASE_URL=postgresql://postgres.your-content-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Optional site settings.
NEXT_PUBLIC_SITE_INDEXABLE=false

# Optional build-time branding.
NEXT_PUBLIC_BASEBUDDY_APP_NAME=BaseBuddy
# NEXT_PUBLIC_BASEBUDDY_DOCS_URL=https://basebuddycms.com/docs
# NEXT_PUBLIC_BASEBUDDY_SUPPORT_URL=https://basebuddycms.com/support

# Optional Supabase Session Pooler TLS certificates.
# Use these when Supabase asks your server connection to verify a pooler root certificate.
# BASEBUDDY_CONTROL_SESSION_POOLER_ROOT_CERTIFICATE_FILE=./certs/control-session-pooler-root.pem
# BASEBUDDY_CONTENT_SESSION_POOLER_ROOT_CERTIFICATE_FILE=./certs/content-session-pooler-root.pem

# Optional shared S3-compatible credentials for mapped media/files.
# BASEBUDDY_S3_ACCESS_KEY_ID=your-s3-access-key-id
# BASEBUDDY_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# Optional separate S3-compatible credentials for mapped media.
# BASEBUDDY_MEDIA_S3_ACCESS_KEY_ID=your-media-s3-access-key-id
# BASEBUDDY_MEDIA_S3_SECRET_ACCESS_KEY=your-media-s3-secret-access-key

# Optional separate S3-compatible credentials for mapped files.
# BASEBUDDY_FILES_S3_ACCESS_KEY_ID=your-files-s3-access-key-id
# BASEBUDDY_FILES_S3_SECRET_ACCESS_KEY=your-files-s3-secret-access-key

# Optional Playwright/local E2E settings.
# BASEBUDDY_ENABLE_TEST_AUTH=1
# PLAYWRIGHT_BASE_URL=http://localhost:3100
# PLAYWRIGHT_PORT=3100
# PLAYWRIGHT_PROJECT_NAME=Playwright Self Host
# PLAYWRIGHT_PROJECT_SLUG=playwright-self-host
# PLAYWRIGHT_OWNER_EMAIL=pw-owner@example.com
# PLAYWRIGHT_OWNER_PASSWORD=replace-with-test-password

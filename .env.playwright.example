# BaseBuddy Playwright/E2E setup
#
# Copy this file to .env.playwright when you want to run local browser tests:
#
#   cp .env.playwright.example .env.playwright
#
# The seed creates BaseBuddy users, projects, mappings, and permissions in
# process.cwd()/basebuddy.config.json. It creates only user-content fixtures in
# the content database.

# Test server
PLAYWRIGHT_PORT=3100
PLAYWRIGHT_BASE_URL=http://localhost:3100
BASEBUDDY_ENABLE_TEST_AUTH=1
BASEBUDDY_PLAYWRIGHT_RUNTIME=1
BASEBUDDY_AUTH_SECRET=replace-with-at-least-32-random-characters

# Content database under test
BASEBUDDY_CONTENT_DATABASE_URL=postgresql://postgres.your-content-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Optional Supabase Storage for mapped media/files fixtures
# For Supabase media bucket storage.
BASEBUDDY_SUPABASE_URL=https://your-project-ref.supabase.co
BASEBUDDY_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
BASEBUDDY_SUPABASE_SECRET_KEY=your-server-key

# Seeded project name
PLAYWRIGHT_PROJECT_NAME=Playwright Self Host
PLAYWRIGHT_PROJECT_SLUG=playwright-self-host

# Seeded local BaseBuddy test users
PLAYWRIGHT_OWNER_EMAIL=pw-owner@example.com
PLAYWRIGHT_OWNER_PASSWORD=replace-with-test-password
PLAYWRIGHT_ADMIN_EMAIL=pw-admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=replace-with-test-password
PLAYWRIGHT_EDITOR_EMAIL=pw-editor@example.com
PLAYWRIGHT_EDITOR_PASSWORD=replace-with-test-password
PLAYWRIGHT_AUTHOR_EMAIL=pw-author@example.com
PLAYWRIGHT_AUTHOR_PASSWORD=replace-with-test-password
PLAYWRIGHT_VIEWER_EMAIL=pw-viewer@example.com
PLAYWRIGHT_VIEWER_PASSWORD=replace-with-test-password

# Optional content database TLS settings
# PLAYWRIGHT_DATABASE_SSL=true
# PLAYWRIGHT_DATABASE_ROOT_CERTIFICATE_FILE=./certs/playwright-session-pooler-root.pem
# BASEBUDDY_CONTENT_SESSION_POOLER_ROOT_CERTIFICATE_FILE=./certs/content-session-pooler-root.pem

# Optional smoke/performance targets
# BASEBUDDY_SCHEMA_ZOO_RUN_KEY=
# BASEBUDDY_LOAD_TEST_PROJECT_ID=
# BASEBUDDY_LOAD_TEST_PROJECT_SLUG=

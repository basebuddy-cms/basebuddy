# BaseBuddy Playwright/E2E setup
#
# Copy this file to .env.playwright when you want to run local browser tests:
#
#   cp .env.playwright.example .env.playwright
#
# Use disposable/local test projects where possible. Playwright tests seed users,
# projects, mappings, and content records.

# Test server
PLAYWRIGHT_PORT=3100
PLAYWRIGHT_BASE_URL=http://localhost:3100
BASEBUDDY_ENABLE_TEST_AUTH=1

# BaseBuddy setup/control database
#
# For a same-project test setup, these can point to the same Supabase/Postgres
# project as the content values below.
BASEBUDDY_CONTROL_SUPABASE_URL=https://your-control-project-ref.supabase.co
BASEBUDDY_CONTROL_SUPABASE_PUBLISHABLE_KEY=your-control-publishable-key
BASEBUDDY_CONTROL_SUPABASE_SECRET_KEY=your-control-secret-key
BASEBUDDY_CONTROL_DATABASE_URL=postgresql://postgres.your-control-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Content database under test
BASEBUDDY_CONTENT_SUPABASE_URL=https://your-content-project-ref.supabase.co
BASEBUDDY_CONTENT_SUPABASE_PUBLISHABLE_KEY=your-content-publishable-key
BASEBUDDY_CONTENT_SUPABASE_SECRET_KEY=your-content-secret-key
BASEBUDDY_CONTENT_DATABASE_URL=postgresql://postgres.your-content-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Legacy/same-project aliases used by older scripts and compatibility paths.
NEXT_PUBLIC_BASEBUDDY_SUPABASE_URL=https://your-control-project-ref.supabase.co
NEXT_PUBLIC_BASEBUDDY_SUPABASE_PUBLISHABLE_KEY=your-control-publishable-key
DATABASE_URL=postgresql://postgres.your-control-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=your-control-secret-key

# Seeded project name
PLAYWRIGHT_PROJECT_NAME=Playwright Self Host
PLAYWRIGHT_PROJECT_SLUG=playwright-self-host

# Seeded test users
PLAYWRIGHT_OWNER_EMAIL=pw-owner@example.com
PLAYWRIGHT_OWNER_PASSWORD=replace-with-test-password
PLAYWRIGHT_ADMIN_EMAIL=pw-admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=replace-with-test-password
PLAYWRIGHT_EDITOR_EMAIL=pw-editor@example.com
PLAYWRIGHT_EDITOR_PASSWORD=replace-with-test-password
PLAYWRIGHT_AUTHOR_EMAIL=pw-author@example.com
PLAYWRIGHT_AUTHOR_PASSWORD=replace-with-test-password
PLAYWRIGHT_VIEWER_EMAIL=pw-viewer@example.com
PLAYWRIGHT_VIEWER_PASSWORD=replace-with-test-password

# Optional Supabase Session Pooler TLS settings.
# Use these only when your database connection requires certificate verification.
# PLAYWRIGHT_DATABASE_SSL=true
# PLAYWRIGHT_DATABASE_ROOT_CERTIFICATE_FILE=./certs/playwright-session-pooler-root.pem
# BASEBUDDY_CONTROL_SESSION_POOLER_ROOT_CERTIFICATE_FILE=./certs/control-session-pooler-root.pem
# BASEBUDDY_CONTENT_SESSION_POOLER_ROOT_CERTIFICATE_FILE=./certs/content-session-pooler-root.pem

# Optional smoke/performance targets.
# BASEBUDDY_SCHEMA_ZOO_RUN_KEY=
# BASEBUDDY_LOAD_TEST_PROJECT_ID=
# BASEBUDDY_LOAD_TEST_PROJECT_SLUG=
